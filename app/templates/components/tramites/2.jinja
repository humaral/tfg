<!-- 
- Autor: Hugo Martín Alonso
- Fecha: 20-10-2025
- Descripción: componente con la información específica del trámite de solicitar una cita en la AEAT. 
-->

<div class="detalles-titulo">
    {%if peticion%}
    <h2>Información</h2>
    {%else%}
    <h2>Introduce los Datos</h2>
    {%endif%}
</div>
<div class="detalles-contenido">
    <div id="contenido-col1">
        <label for="cita-aeat-dni">DNI:</label>
        <input type="text" id="cita-aeat-dni" name="dni" {%if peticion%}value="{{peticion.informacion.dni}}" {%if peticion and (peticion.estadoActual.valor != "Asignada")%}readonly{%endif%}{%endif%} required>
        <label for="cita-aeat-nombre">Nombre:</label>
        <input type="text" id="cita-aeat-nombre" name="nombre" {%if peticion%}value="{{peticion.informacion.nombre}}" {%if peticion and (peticion.estadoActual.valor != "Asignada")%}readonly{%endif%}{%endif%} required>
        <label for="cita-aeat-servicio">Servicio:</label>
        <select id="cita-aeat-servicio" name="servicio" {%if peticion and (peticion.estadoActual.valor != "Asignada")%}disabled{%endif%} required>
            {# TODO añadir todas las opciones del select #}
            <option value="renta" {%if peticion and peticion.informacion.servicio == 'Renta'%}selected{%endif%}>Renta</option>
        </select>
    </div>
    <div id="contenido-col2">
        <label for="cita-aeat-modalidad">Modalidad:</label>
        <button id="cita-aeat-modalidad" type="button" data-modalidad="{% if peticion and peticion.informacion.modalidad == 'presencial' %}presencial{% else %}virtual{% endif %}" {%if peticion and (peticion.estadoActual.valor != "Asignada")%}disabled{%endif%}>
            <iconify-icon {%if peticion and peticion.informacion.modalidad == 'presencial'%}icon="raphael:employee"{%else%}icon="tabler:video"{%endif%}></iconify-icon>
            <p>{%if peticion and peticion.informacion.modalidad == 'presencial'%}Presencial{%else%}Virtual{%endif%}</p>
        </button>
        <label id="cita-aeat-label-oficina" for="cita-aeat-oficina">Oficina:</label>
        <div id="cita-aeat-oficina">
            <iconify-icon icon="streamline-plump:building-office-remix"></iconify-icon>
            {# TODO cambiarlo a select #}
            <input type="text" id="cita-aeat-campo-oficina" name="oficina" {%if peticion%}value="{{peticion.informacion.oficina}}" {%if peticion and (peticion.estadoActual.valor != "Asignada")%}readonly{%endif%}{%endif%} required>
        </div>
        <label id="cita-aeat-label-fecha" for="cita-aeat-fecha">Fecha:</label>
        <div id="cita-aeat-fecha">
            <iconify-icon icon="mdi:calendar-clock-outline"></iconify-icon>
            <input type="date" id="cita-aeat-dia" name="dia" {%if peticion%}value="{{peticion.informacion.dia}}" {%if peticion and (peticion.estadoActual.valor != "Asignada")%}readonly{%endif%}{%endif%} required>
            <iconify-icon icon="tabler:clock-hour-2"></iconify-icon>
            <input type="time" id="cita-aeat-hora" name="hora" {%if peticion%}value="{{peticion.informacion.hora}}" {%if peticion and (peticion.estadoActual.valor != "Asignada")%}readonly{%endif%}{%endif%} required>
        </div>
        <label id="cita-aeat-label-email" for="cita-aeat-email">Email:</label>
        <input type="email" id="cita-aeat-email" name="email" {%if peticion%}value="{{peticion.informacion.email}}" {%if peticion and (peticion.estadoActual.valor != "Asignada")%}readonly{%endif%}{%endif%} required>

    </div>

</div>